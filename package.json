{
  "name": "aca-erp",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "node server/dev.js",
    "dev:client": "npm run dev --prefix client",
    "build": "cd client && npm run build",
    "vercel-build": "cd client && npm install && npm run build",
    "seed": "node server/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
