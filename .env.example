# MongoDB Atlas 등 연결 문자열
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/aca_erp?retryWrites=true&w=majority

# JWT 서명용 비밀 — 비어 있으면 /api/auth/login 이 500 오류가 납니다. openssl rand -base64 48 등으로 생성
JWT_SECRET=개발용_임의_문자열_반드시_교체

# 로컬 API 포트 (Vite 프록시와 맞춤)
PORT=3001

# npm run seed — 기본: 기존 시드 컬렉션 삭제 후 대량 샘플 삽입
# SEED_ADMIN_EMAIL=test@test.com
# SEED_ADMIN_PASSWORD=test1234
# SEED_ADMIN_NAME=개발용 관리자
# 삭제 없이 이어 붙이려면 (거의 안 씀)
# SEED_SKIP_RESET=1
